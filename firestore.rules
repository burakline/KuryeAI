rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: each user can read/write their own document and subcollections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /shifts/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /ledger/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /orders/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // AcilTalepler: authenticated users can create; owner or accepted kurye can read/update
    match /acilTalepler/{talepId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        resource.data.status == 'open'
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Public read collections
    match /basvurular/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /ayarlar/{doc} {
      allow read, write: if request.auth != null;
    }
    match /fiyatlar/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
