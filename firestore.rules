rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Yardımcı Fonksiyonlar ───────────────────────────────────────────────

    // Kullanıcının rolünü Firestore'dan çeker
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isKurye() {
      return isSignedIn() && userRole() == 'kurye';
    }

    function isRestoran() {
      return isSignedIn() && userRole() == 'restoran';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ─── users/{userId} ──────────────────────────────────────────────────────
    // Kullanıcı kendi profilini okur/yazar; admin hepsini okuyabilir
    match /users/{userId} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();

      match /shifts/{doc} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /ledger/{doc} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /orders/{doc} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // ─── orders (üst seviye koleksiyon) ─────────────────────────────────────
    // Admin → tam erişim
    // Kurye → sadece kendine atanmış siparişler (courierId)
    // Restoran → sadece kendi siparişleri (restaurantId)
    match /orders/{orderId} {
      allow read, write: if isAdmin();

      // Kurye: kendine atanmış siparişi okuyabilir ve güncelleyebilir
      allow read, update: if isKurye()
        && resource.data.courierId == request.auth.uid;

      // Restoran: kendi siparişlerini okuyabilir ve güncelleyebilir
      allow read, update: if isRestoran()
        && resource.data.restaurantId == request.auth.uid;

      // Restoran yeni sipariş oluşturabilir (kendi restaurantId'si ile)
      allow create: if isRestoran()
        && request.resource.data.restaurantId == request.auth.uid;
    }

    // ─── acilTalepler ────────────────────────────────────────────────────────
    // Oluşturan kullanıcı ve atanan kurye erişebilir
    // Kuryeler açık görevleri (status == 'open') görebilir ve kabul edebilir
    match /acilTalepler/{talepId} {

      allow read: if isSignedIn() && (
        isAdmin() ||
        isKurye() ||
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.courierId
      );

      // Oluşturma: herhangi bir giriş yapmış kullanıcı, kendi userId'si ile
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn() && (
        isAdmin() ||
        // Talep sahibi kendi talebini güncelleyebilir
        request.auth.uid == resource.data.userId ||
        // Kurye açık görev kabul edebilir veya üstlendiği görevi güncelleyebilir
        (isKurye() && (
          resource.data.status == 'open' ||
          resource.data.courierId == request.auth.uid
        ))
      );

      allow delete: if isAdmin()
        || (isSignedIn() && request.auth.uid == resource.data.userId);
    }

    // ─── chats ───────────────────────────────────────────────────────────────
    // Sadece sohbet katılımcıları (participants dizisi) erişebilir
    match /chats/{roomId} {
      allow read, update: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid in resource.data.participants
      );

      // Yeni sohbet oluşturan kullanıcı kendi uid'sini participants'a eklemeli
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants;

      match /messages/{msgId} {
        allow read, write: if isSignedIn() && (
          isAdmin() ||
          request.auth.uid in
            get(/databases/$(database)/documents/chats/$(roomId)).data.participants
        );
      }
    }

    // ─── basvurular ──────────────────────────────────────────────────────────
    // Herhangi bir giriş yapmış kullanıcı başvuru oluşturabilir
    // Okuma, güncelleme, silme → yalnızca admin
    match /basvurular/{doc} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // ─── ayarlar ─────────────────────────────────────────────────────────────
    // Giriş yapmış herkes okuyabilir; sadece admin yazabilir
    match /ayarlar/{doc} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── fiyatlar ────────────────────────────────────────────────────────────
    // Giriş yapmış herkes okuyabilir; sadece admin yazabilir
    match /fiyatlar/{doc} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── zones ───────────────────────────────────────────────────────────────
    // Admin yazar; giriş yapmış herkes okur
    match /zones/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── giderler ────────────────────────────────────────────────────────────
    // Sadece admin okur/yazar
    match /giderler/{doc} {
      allow read, write: if isAdmin();
    }

    // ─── broadcasts ──────────────────────────────────────────────────────────
    // Admin yazar; giriş yapmış herkes okur (bildirim almak için)
    match /broadcasts/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── izinciTalepler ──────────────────────────────────────────────────────
    match /izinciTalepler/{doc} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.isverenId ||
        isKurye()
      );
      allow create: if isSignedIn()
        && request.resource.data.isverenId == request.auth.uid;
      allow update: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.isverenId ||
        isKurye()
      );
      allow delete: if isAdmin()
        || (isSignedIn() && request.auth.uid == resource.data.isverenId);
    }

    // ─── izinciTeklifler ─────────────────────────────────────────────────────
    match /izinciTeklifler/{doc} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.kureyeId == request.auth.uid;
      allow update: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.isverenId ||
        request.auth.uid == resource.data.kureyeId
      );
      allow delete: if isAdmin();
    }
  }
}
