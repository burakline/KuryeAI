{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/adminai",     "destination": "/adminai-panel",     "permanent": false },
    { "source": "/kuryesefai",  "destination": "/kuryesefai-login",  "permanent": false },
    { "source": "/acil-kurye",  "destination": "/acilkuryeai",       "permanent": true }
  ],
  "rewrites": [
    { "source": "/kuryeai",                        "destination": "/kuryeai.html" },
    { "source": "/kuryeai-login",                  "destination": "/kuryeai-login.html" },
    { "source": "/kuryeai-panel",                  "destination": "/kuryeai-panel.html" },
    { "source": "/restoranai",                     "destination": "/restoranai.html" },
    { "source": "/restoranai-login",               "destination": "/restoranai-login.html" },
    { "source": "/restoranai-panel",               "destination": "/restoranai-panel.html" },
    { "source": "/adminai",                        "destination": "/adminai-panel.html" },
    { "source": "/adminai-login",                  "destination": "/adminai-login.html" },
    { "source": "/adminai-panel",                  "destination": "/adminai-panel.html" },
    { "source": "/acilkuryeai",                    "destination": "/acilkuryeai.html" },
    { "source": "/acilkuryeai-kurye-login",        "destination": "/acilkuryeai-kurye-login.html" },
    { "source": "/acilkuryeai-kurye-panel",        "destination": "/acilkuryeai-kurye-panel.html" },
    { "source": "/acilkuryeai-talepeden-login",    "destination": "/acilkuryeai-talepeden-login.html" },
    { "source": "/acilkuryeai-talepeden-panel",    "destination": "/acilkuryeai-talepeden-panel.html" },
    { "source": "/izincikuryeai",                  "destination": "/izincikuryeai.html" },
    { "source": "/izincikuryeai-izinci-login",     "destination": "/izincikuryeai-izinci-login.html" },
    { "source": "/izincikuryeai-izinci-panel",     "destination": "/izincikuryeai-izinci-panel.html" },
    { "source": "/izincikuryeai-isveren-login",    "destination": "/izincikuryeai-isveren-login.html" },
    { "source": "/izincikuryeai-isveren-panel",    "destination": "/izincikuryeai-isveren-panel.html" },
    { "source": "/auth-action",                    "destination": "/auth-action.html" },
    { "source": "/reset-password",                 "destination": "/reset-password.html" },
    { "source": "/kuryesefai",                     "destination": "/kuryesefai-login.html" },
    { "source": "/kuryesefai-login",               "destination": "/kuryesefai-login.html" },
    { "source": "/kuryesefai-panel",               "destination": "/kuryesefai-panel.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://www.gstatic.com/firebasejs/ https://unpkg.com/ https://tile.openstreetmap.org 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com/; img-src 'self' data: https: blob:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://kuryeai-default-rtdb.europe-west1.firebasedatabase.app https://kuryeai-99bf9-default-rtdb.europe-west1.firebasedatabase.app https://*.cloudfunctions.net https://firebaseinstallations.googleapis.com https://router.project-osrm.org https://nominatim.openstreetmap.org wss://*.firebaseio.com wss://kuryeai-default-rtdb.europe-west1.firebasedatabase.app wss://kuryeai-99bf9-default-rtdb.europe-west1.firebasedatabase.app wss:; frame-src 'none'; object-src 'none';" }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|svg|ico|webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
