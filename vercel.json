{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/restoran", "destination": "/restoran.html" },
    { "source": "/kurye", "destination": "/kurye.html" },
    { "source": "/restoran-login", "destination": "/restoran-login.html" },
    { "source": "/kurye-login", "destination": "/kurye-login.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|svg|ico|webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
