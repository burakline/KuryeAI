{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/kuryeai",               "destination": "/kuryeai.html" },
    { "source": "/kurye-login",           "destination": "/kurye-login.html" },
    { "source": "/kurye-panel",           "destination": "/kurye-panel.html" },
    { "source": "/restoranai",            "destination": "/restoranai.html" },
    { "source": "/restoran-login",        "destination": "/restoran-login.html" },
    { "source": "/restoran-panel",        "destination": "/restoran-panel.html" },
    { "source": "/adminai",               "destination": "/adminai.html" },
    { "source": "/admin-panel",           "destination": "/admin-panel.html" },
    { "source": "/acilkuryeai",                   "destination": "/acilkuryeai.html" },
    { "source": "/acilkuryeai-kurye-login",        "destination": "/acilkuryeai-kurye-login.html" },
    { "source": "/acilkuryeai-kurye-panel",        "destination": "/acilkuryeai-kurye-panel.html" },
    { "source": "/acilkuryeai-talepeden-login",    "destination": "/acilkuryeai-talepeden-login.html" },
    { "source": "/acilkuryeai-talepeden-panel",    "destination": "/acilkuryeai-talepeden-panel.html" },
    { "source": "/izincikuryeai",                  "destination": "/izincikuryeai.html" },
    { "source": "/izincikuryeai-izinci-login",     "destination": "/izincikuryeai-izinci-login.html" },
    { "source": "/izincikuryeai-izinci-panel",     "destination": "/izincikuryeai-izinci-panel.html" },
    { "source": "/izincikuryeai-isveren-login",    "destination": "/izincikuryeai-isveren-login.html" },
    { "source": "/izincikuryeai-isveren-panel",    "destination": "/izincikuryeai-isveren-panel.html" },
    { "source": "/auth-action",           "destination": "/auth-action.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|svg|ico|webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
