{
  "cleanUrls": true,
  "trailingSlash": false,
  "injectContentSecurityPolicy": false,
  "rewrites": [
    { "source": "/kurye",                  "destination": "/kurye.html" },
    { "source": "/kurye-login",            "destination": "/kurye-login.html" },
    { "source": "/kurye-panel",            "destination": "/kurye-panel.html" },
    { "source": "/restoran",               "destination": "/restoran.html" },
    { "source": "/restoran-login",         "destination": "/restoran-login.html" },
    { "source": "/restoran-panel",         "destination": "/restoran-panel.html" },
    { "source": "/admin",                  "destination": "/admin-login.html" },
    { "source": "/admin-panel",            "destination": "/admin-panel.html" },
    { "source": "/acilkurye",              "destination": "/acilkurye.html" },
    { "source": "/acilkurye-login",        "destination": "/acilkurye-login.html" },
    { "source": "/acilkurye-panel",        "destination": "/acilkurye-panel.html" },
    { "source": "/acilkurye-talep-login",  "destination": "/acilkurye-talep-login.html" },
    { "source": "/acilkurye-talep-panel",  "destination": "/acilkurye-talep-panel.html" },
    { "source": "/izincikurye",            "destination": "/izincikurye.html" },
    { "source": "/izincikurye-login",      "destination": "/izincikurye-login.html" },
    { "source": "/izincikurye-panel",      "destination": "/izincikurye-panel.html" },
    { "source": "/auth-action",            "destination": "/auth-action.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|svg|ico|webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
