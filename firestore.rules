rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Yardımcı Fonksiyonlar ───────────────────────────────────────────────

    // Kullanıcının rolünü Firestore'dan çeker
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isKurye() {
      return isSignedIn() && userRole() == 'kurye';
    }

    function isRestoran() {
      return isSignedIn() && userRole() == 'restoran';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isBolgeSefi() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isZoneChief == true;
    }

    // ─── Hassas alan koruma yardımcısı ──────────────────────────────────────
    // Kullanıcının kendi belgesini yazarken role/isZoneChief/status/plan alanlarını
    // değiştirmesini engeller (privilege escalation önlemi)
    function notEscalating() {
      return !request.resource.data.diff(resource.data)
               .affectedKeys()
               .hasAny(['role', 'isZoneChief', 'status', 'plan']);
    }

    // ─── users/{userId} ──────────────────────────────────────────────────────
    match /users/{userId} {
      // Restoran: kendi bölgesindeki kuryeleri (Kurye Bul & Ekle) okuyabilir
      allow read:  if isOwner(userId) || isAdmin() || isBolgeSefi()
                   || (isRestoran() && resource.data.role == 'kurye' && resource.data.status == 'active');
      // Admin: tüm alanları yazabilir
      // Kullanıcı: kendi belgesi üzerinde role/isZoneChief/status/plan değiştiremez
      allow write: if isAdmin();
      allow write: if isOwner(userId) && notEscalating();

      match /shifts/{doc} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /ledger/{doc} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /orders/{doc} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // ─── orders (üst seviye koleksiyon) ─────────────────────────────────────
    // Admin → tam erişim
    // Kurye → sadece kendine atanmış siparişler (courierId)
    // Restoran → sadece kendi siparişleri (restaurantId)
    match /orders/{orderId} {
      allow read, write: if isAdmin();

      // Bölge şefi: siparişleri sadece okuyabilir (değiştiremez)
      allow read: if isBolgeSefi();

      // Kurye: kendine atanmış siparişi okuyabilir ve güncelleyebilir
      // Not: Kod 'courier' alanını kullanır; courierId geriye dönük uyumluluk için
      allow read, update: if isKurye()
        && (resource.data.courier == request.auth.uid
            || resource.data.courierId == request.auth.uid);

      // Restoran: kendi siparişlerini okuyabilir ve güncelleyebilir
      allow read, update: if isRestoran()
        && resource.data.restaurantId == request.auth.uid;

      // Restoran yeni sipariş oluşturabilir (kendi restaurantId'si ile)
      allow create: if isRestoran()
        && request.resource.data.restaurantId == request.auth.uid;
    }

    // ─── acilTalepler ────────────────────────────────────────────────────────
    // Oluşturan kullanıcı ve atanan kurye erişebilir
    // Kuryeler açık görevleri (status == 'open') görebilir ve kabul edebilir
    match /acilTalepler/{talepId} {

      allow read: if isSignedIn() && (
        isAdmin() ||
        isKurye() ||
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.courierId
      );

      // Oluşturma: herhangi bir giriş yapmış kullanıcı, kendi userId'si ile
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn() && (
        isAdmin() ||
        // Talep sahibi kendi talebini güncelleyebilir
        request.auth.uid == resource.data.userId ||
        // Kurye açık görev kabul edebilir veya üstlendiği görevi güncelleyebilir
        (isKurye() && (
          resource.data.status == 'open' ||
          resource.data.courierId == request.auth.uid
        ))
      );

      allow delete: if isAdmin()
        || (isSignedIn() && request.auth.uid == resource.data.userId);
    }

    // ─── chats ───────────────────────────────────────────────────────────────
    // Sadece sohbet katılımcıları (participants dizisi) erişebilir
    match /chats/{roomId} {
      allow read, update: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid in resource.data.participants
      );

      // Yeni sohbet oluşturan kullanıcı kendi uid'sini participants'a eklemeli
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants;

      match /messages/{msgId} {
        // Sadece sohbet odasının katılımcıları mesajları okuyup yazabilir
        allow read, write: if isSignedIn() && (
          isAdmin() ||
          request.auth.uid in get(/databases/$(database)/documents/chats/$(roomId)).data.participants
        );
      }
    }

    // ─── basvurular ──────────────────────────────────────────────────────────
    // Herhangi bir giriş yapmış kullanıcı başvuru oluşturabilir
    // Okuma, güncelleme, silme → yalnızca admin
    match /basvurular/{doc} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // ─── ayarlar ─────────────────────────────────────────────────────────────
    // Giriş yapmış herkes okuyabilir; sadece admin yazabilir
    match /ayarlar/{doc} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── fiyatlar ────────────────────────────────────────────────────────────
    // Giriş yapmış herkes okuyabilir; sadece admin yazabilir
    match /fiyatlar/{doc} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── zones ───────────────────────────────────────────────────────────────
    // Admin yazar; giriş yapmış herkes okur
    match /zones/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── giderler ────────────────────────────────────────────────────────────
    // Sadece admin okur/yazar
    match /giderler/{doc} {
      allow read, write: if isAdmin();
    }

    // ─── broadcasts ──────────────────────────────────────────────────────────
    // Admin yazar; giriş yapmış herkes okur (bildirim almak için)
    match /broadcasts/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── izinciTalepler ──────────────────────────────────────────────────────
    match /izinciTalepler/{doc} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.isverenId ||
        isKurye()
      );
      allow create: if isSignedIn()
        && request.resource.data.isverenId == request.auth.uid;
      allow update: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.isverenId ||
        isKurye()
      );
      allow delete: if isAdmin()
        || (isSignedIn() && request.auth.uid == resource.data.isverenId);
    }

    // ─── izinciTeklifler ─────────────────────────────────────────────────────
    match /izinciTeklifler/{doc} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.kuryeId == request.auth.uid;
      allow update: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.isverenId ||
        request.auth.uid == resource.data.kuryeId
      );
      allow delete: if isAdmin();
    }

    // ─── contact_messages ────────────────────────────────────────────────────
    // İletişim formu: herkes gönderebilir; sadece admin okuyabilir
    match /contact_messages/{doc} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ─── blog_posts (beğeni sayacı) ──────────────────────────────────────────
    // Herkes okuyabilir; giriş yapmış kullanıcılar beğeni sayacını güncelleyebilir
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ─── blog_likes ──────────────────────────────────────────────────────────
    // Giriş yapmış kullanıcı kendi beğenisini okur/yazar/siler
    match /blog_likes/{likeId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource == null ||
        request.auth.uid == resource.data.uid
      );
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.uid == request.auth.uid;
    }

    // ─── blog_comments ───────────────────────────────────────────────────────
    // Herkes okuyabilir; giriş yapmış kullanıcılar yorum ekleyebilir
    match /blog_comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && (
        isAdmin() ||
        resource.data.uid == request.auth.uid
      );
    }
  }
}
